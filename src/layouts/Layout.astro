---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Nick | UX Designer & Writer',
	description = 'Personal website with UX portfolio work and blog posts.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<script is:inline>
			(function () {
				if (localStorage.getItem('theme') === 'light') {
					document.documentElement.setAttribute('data-theme', 'light');
				}
			})();
		</script>
	</head>
	<body>
		<header class="site-header">
			<div class="wrap">
				<a class="brand" href="/">Nick</a>
				<div class="header-right">
					<nav aria-label="Main navigation">
						<a href="/work">Work</a>
						<a href="/blog">Blog</a>
						<a href="/about">About</a>
					</nav>
					<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
						<svg class="icon-moon" width="1em" height="1em" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M15.0298 2.48972C14.1569 2.21472 13.4108 3.16871 13.8735 3.95871C14.6045 5.20471 14.9985 6.61072 14.9985 8.02072C14.9985 12.4387 11.4168 16.0207 6.99848 16.0207C6.16658 16.0207 5.32518 15.8857 4.56098 15.6457C3.68808 15.3707 2.91068 16.3247 3.37348 17.1147C5.15098 20.1467 8.39968 22.0207 11.9985 22.0207C17.5213 22.0207 21.9985 17.5437 21.9985 12.0207C21.9985 7.61972 19.158 3.78772 15.0298 2.48972ZM16.6235 5.48972C18.6876 6.94871 19.9985 9.35371 19.9985 12.0207C19.9985 16.4387 16.4168 20.0207 11.9985 20.0207C9.97038 20.0207 8.11658 19.2407 6.68598 17.9587C6.79268 17.9617 6.89218 18.0207 6.99848 18.0207C12.5214 18.0207 16.9985 13.5437 16.9985 8.02072C16.9985 7.16372 16.8465 6.31571 16.6235 5.48972Z" fill="currentColor"/>
						</svg>
						<svg class="icon-sun" width="1em" height="1em" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M12.0137 1.95312C11.4617 1.95312 11.0137 2.40113 11.0137 2.95313V4.95313C11.0137 5.50513 11.4617 5.95313 12.0137 5.95313C12.5657 5.95313 13.0137 5.50513 13.0137 4.95313V2.95313C13.0137 2.40113 12.5657 1.95312 12.0137 1.95312ZM5.63867 4.57813C5.38267 4.57813 5.14667 4.69513 4.95167 4.89113C4.56067 5.28113 4.56067 5.90712 4.95167 6.29712L6.29467 7.67212C6.68567 8.06212 7.34266 8.06312 7.73266 7.67212C8.12266 7.28112 8.12366 6.62413 7.73266 6.23413L6.35766 4.89113C6.16166 4.69513 5.89467 4.57813 5.63867 4.57813ZM18.3577 4.60913C18.1017 4.60913 17.8657 4.69513 17.6697 4.89113L16.2947 6.23413C15.9047 6.62513 15.9047 7.28112 16.2947 7.67212C16.6857 8.06212 17.3417 8.06212 17.7327 7.67212L19.0757 6.29712C19.4667 5.90612 19.4667 5.28113 19.0757 4.89113C18.8807 4.69513 18.6137 4.60913 18.3577 4.60913ZM12.0137 6.95313C9.25267 6.95313 7.01367 9.19213 7.01367 11.9531C7.01367 14.7141 9.25267 16.9531 12.0137 16.9531C14.7747 16.9531 17.0137 14.7141 17.0137 11.9531C17.0137 9.19213 14.7747 6.95313 12.0137 6.95313ZM12.0137 8.95313C13.6707 8.95313 15.0137 10.2961 15.0137 11.9531C15.0137 13.6101 13.6707 14.9531 12.0137 14.9531C10.3567 14.9531 9.01367 13.6101 9.01367 11.9531C9.01367 10.2961 10.3567 8.95313 12.0137 8.95313ZM3.01367 10.9531C2.46167 10.9531 2.01367 11.4011 2.01367 11.9531C2.01367 12.5051 2.46167 12.9531 3.01367 12.9531H5.01367C5.56567 12.9531 6.01367 12.5051 6.01367 11.9531C6.01367 11.4011 5.56567 10.9531 5.01367 10.9531H3.01367ZM19.0137 10.9531C18.4617 10.9531 18.0137 11.4011 18.0137 11.9531C18.0137 12.5051 18.4617 12.9531 19.0137 12.9531H21.0137C21.5657 12.9531 22.0137 12.5051 22.0137 11.9531C22.0137 11.4011 21.5657 10.9531 21.0137 10.9531H19.0137ZM7.01367 15.9531C6.75767 15.9521 6.49067 16.0391 6.29467 16.2341L4.91968 17.6091C4.52868 17.9991 4.53068 18.6241 4.91968 19.0151C5.30968 19.4071 5.96566 19.4051 6.35766 19.0151L7.73266 17.6721C8.12366 17.2821 8.12166 16.6261 7.73266 16.2341C7.53766 16.0391 7.26967 15.9541 7.01367 15.9531ZM17.0137 15.9531C16.7577 15.9531 16.4897 16.0391 16.2947 16.2341C15.9047 16.6251 15.9037 17.2821 16.2947 17.6721L17.7017 19.0471C18.0917 19.4371 18.7177 19.4381 19.1077 19.0471C19.4977 18.6561 19.4987 17.9991 19.1077 17.6091L17.7327 16.2341C17.5367 16.0391 17.2697 15.9531 17.0137 15.9531ZM12.0137 17.9531C11.4617 17.9531 11.0137 18.4011 11.0137 18.9531V20.9531C11.0137 21.5051 11.4617 21.9531 12.0137 21.9531C12.5657 21.9531 13.0137 21.5051 13.0137 20.9531V18.9531C13.0137 18.4011 12.5657 17.9531 12.0137 17.9531Z" fill="currentColor"/>
						</svg>
					</button>
				</div>
			</div>
		</header>
		<main class="wrap">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="wrap">
				<p>© {new Date().getFullYear()} Nick. UX freelance practice and personal writing.</p>
				<p><a href="/imprint">Imprint</a></p>
			</div>
		</footer>
		<script is:inline>
			document.getElementById('theme-toggle').addEventListener('click', function () {
				var isLight = document.documentElement.getAttribute('data-theme') === 'light';
				if (isLight) {
					document.documentElement.removeAttribute('data-theme');
					localStorage.setItem('theme', 'dark');
				} else {
					document.documentElement.setAttribute('data-theme', 'light');
					localStorage.setItem('theme', 'light');
				}
			});
		</script>
	</body>
</html>

<style is:global>
	@font-face {
		font-family: 'Inter';
		src: url('../assets/fonts/Inter-VariableFont.ttf') format('truetype');
		font-style: normal;
		font-weight: 100 900;
		font-display: swap;
	}

	@font-face {
		font-family: 'Inter';
		src: url('../assets/fonts/Inter-Italic-VariableFont.ttf') format('truetype');
		font-style: italic;
		font-weight: 100 900;
		font-display: swap;
	}

	:root {
		--bg: #19485f;
		--surface: #1e546e;
		--text: #d9e0a4;
		--muted: #a8b87a;
		--accent: #d9e0a4;
		--line: rgba(217, 224, 164, 0.2);
		--container-max: 900px;
		--container-gutter: 1rem;
	}

	[data-theme='light'] {
		--bg: #FAF9F5;
		--surface: #F0EDE6;
		--text: #1C1917;
		--muted: #6B6460;
		--accent: #DE7356;
		--line: #DDD9D2;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		font-family: 'Inter', sans-serif;
		font-weight: 300;
		background: var(--bg);
		color: var(--text);
		transition: background 0.2s, color 0.2s;
	}

	h1, h2, h3, h4, h5, h6, strong {
		font-weight: 600;
	}

	button,
	[role='button'],
	input[type='button'],
	input[type='submit'],
	input[type='reset'] {
		font-weight: 400;
	}

	a,
	a:link,
	a:visited,
	a:hover,
	a:active {
		color: var(--text);
	}

	.icon-sun {
		display: none;
	}

	[data-theme='light'] .icon-moon {
		display: none;
	}

	[data-theme='light'] .icon-sun {
		display: block;
	}
</style>

<style>
	.wrap {
		width: min(var(--container-max), calc(100% - (var(--container-gutter) * 2)));
		margin: 0 auto;
	}

	.site-header {
		border-bottom: 1px solid var(--line);
		backdrop-filter: blur(2px);
	}

	.site-header .wrap {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
	}

	.header-right {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.brand {
		font-size: 1.2rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-decoration: none;
	}

	nav {
		display: flex;
		gap: 1rem;
	}

	nav a {
		text-decoration: none;
		font-weight: 300;
		color: var(--muted);
	}

	nav a:hover {
		color: var(--accent);
	}

	.theme-toggle {
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
		font-size: 1.1rem;
		color: var(--muted);
		display: flex;
		align-items: center;
	}

	.theme-toggle:hover {
		color: var(--accent);
	}

	main {
		padding: 2.25rem 0 2.5rem;
	}

	.site-footer .wrap {
		border-top: 1px solid var(--line);
		padding: 1.25rem 0 2rem;
		color: var(--muted);
		font-size: 0.9rem;
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: center;
		gap: 1rem;
	}

	.site-footer p {
		margin: 0;
	}

	.site-footer a {
		text-decoration: none;
		color: var(--muted);
	}

	.site-footer a:hover {
		color: var(--accent);
	}

	@media (max-width: 720px) {
		nav {
			gap: 0.75rem;
			font-size: 0.95rem;
		}

		.site-footer .wrap {
			grid-template-columns: 1fr;
			align-items: flex-start;
		}
	}
</style>
